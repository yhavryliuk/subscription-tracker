{
  "name": "subscription-tracker",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --filter=!storybook",
    "api:dev": "pnpm --filter api dev",
    "web:dev": "pnpm --filter web dev",
    "test": "turbo run test",
    "ui:test": "pnpm --filter ui test",
    "storybook": "pnpm --filter storybook storybook",
    "prisma:dev": "pnpm prisma migrate dev --name init",
    "graphql:sync": "turbo run graphql:sync --force"
  },
  "packageManager": "pnpm@10.28.0",
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.7.5",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=20"
  }
}
